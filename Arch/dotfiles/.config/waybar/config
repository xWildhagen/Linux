{
  "layer": "top",
  "position": "top",
  "height": 32,
  "margin-top": 6,
  "margin-left": 6,
  "margin-right": 6,
  "modules-left": [
    "hyprland/workspaces",
    "hyprland/window"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "cpu",
    "memory",
    "pulseaudio",
    "backlight",
    "battery",
    "network",
    "tray"
  ],

  "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "hyprctl dispatch workspace {id}",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "format-icons": {
      "1": "",
      "2": "",
      "3": "",
      "4": "",
      "5": "",
      "default": ""
    }
  },

  "hyprland/window": {
    "format": "{}",
    "max-length": 60,
    "separate-outputs": false
  },

  "clock": {
    "format": "{:%a %d %b  %H:%M}",
    "tooltip-format": "{:%Y-%m-%d %H:%M:%S}",
    "interval": 1
  },

  "cpu": {
    "format": " {usage:2}%",
    "tooltip": true,
    "interval": 5
  },

  "memory": {
    "format": " {used:0.1f}G",
    "interval": 5
  },

  "pulseaudio": {
    "format": "{icon} {volume:2}%",
    "format-muted": " 0%",
    "on-click": "pavucontrol",
    "scroll-step": 2,
    "format-icons": {
      "default": [
        "",
        "",
        ""
      ]
    }
  },

  "backlight": {
    "format": " {percent:2}%",
    "device": "intel_backlight"
  },

  "battery": {
    "format": "{icon} {capacity:2}%",
    "format-charging": " {capacity:2}%",
    "format-full": " {capacity:2}%",
    "interval": 30,
    "states": {
      "warning": 25,
      "critical": 10
    },
    "format-icons": [
      "",
      "",
      "",
      "",
      ""
    ]
  },

  "network": {
    "format-wifi": " {signalStrength}%",
    "format-ethernet": " {ifname}",
    "format-disconnected": "",
    "tooltip-format": "{ifname} via {gwaddr}\nIP: {ipaddr}",
    "interval": 5
  },

  "tray": {
    "icon-size": 16,
    "spacing": 8
  }
}
